{
  "expo": {
    "name": "Bubble Bar",
    "slug": "bubble-bar",
    "version": "1.0.0",
    "scheme": "bubblebar",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0D0A1F"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMotionUsageDescription": "用于气泡重力感应漂浮效果"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0A1F"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
